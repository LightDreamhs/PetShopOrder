<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petshop.order.mapper.AppUserMapper">

    <select id="selectByPhone" resultType="com.petshop.order.entity.AppUser">
        SELECT * FROM app_user WHERE phone = #{phone}
    </select>

    <select id="selectById" resultType="com.petshop.order.entity.AppUser">
        SELECT * FROM app_user WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO app_user (phone, status, last_login_time)
        VALUES (#{phone}, #{status}, #{lastLoginTime})
    </insert>

    <update id="updateLastLoginTime">
        UPDATE app_user SET last_login_time = #{lastLoginTime} WHERE id = #{id}
    </update>

</mapper>
