<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petshop.order.mapper.AdminUserMapper">

    <select id="selectByUsername" resultType="com.petshop.order.entity.AdminUser">
        SELECT * FROM admin_user WHERE username = #{username}
    </select>

    <select id="selectById" resultType="com.petshop.order.entity.AdminUser">
        SELECT * FROM admin_user WHERE id = #{id}
    </select>

    <update id="updateLastLoginTime">
        UPDATE admin_user SET last_login_time = #{lastLoginTime} WHERE id = #{id}
    </update>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO admin_user (username, password_hash, real_name, role, status)
        VALUES (#{username}, #{passwordHash}, #{realName}, #{role}, #{status})
    </insert>

</mapper>
