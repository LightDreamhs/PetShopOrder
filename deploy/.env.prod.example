# ============================================
# PetShopOrder 生产环境变量模板
# ============================================
# 用法：cp .env.prod.example .env.prod，填入真实值后供 docker compose 使用。
# ⚠️ .env.prod 绝不提交 git（.gitignore 已忽略 .env*）。敏感值缺失会导致容器启动失败。

# ---------- Profile ----------
SPRING_PROFILES_ACTIVE=prod

# ---------- 数据库 ----------
DB_NAME=petshop_order
DB_ROOT_PASSWORD=          # 【必填】生成随机强密码，如 openssl rand -base64 24

# ---------- Admin 初始化（首次启动创建 BOSS 账号）----------
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=       # 【必填】设定强密码

# ---------- Webhook AES key（飞书/企微通知加解密）----------
# 兼容历史已加密数据，默认 PetShop2026Order!；更换需同步迁移历史密文
WEBHOOK_AES_KEY=PetShop2026Order!

# ---------- Sa-Token ----------
SA_TOKEN_TIMEOUT=2592000
SA_TOKEN_ACTIVE_TIMEOUT=2592000
SATOKEN_SAME_SITE=Lax

# ---------- 短信（阿里云 PNVS）----------
SMS_PROVIDER=log           # 生产改 aliyun 启用真实短信验证码
ALIYUN_SMS_AK=             # SMS_PROVIDER=aliyun 时必填（见仓库外备份的凭据 txt）
ALIYUN_SMS_SK=             # SMS_PROVIDER=aliyun 时必填
ALIYUN_SMS_SIGN=速通互联验证码
ALIYUN_SMS_TEMPLATE=100001

# ---------- nginx 配置选择（证书申请流程用，一般无需手改）----------
# 留空 → 挂 nginx.http-only.conf（首次启动 / 申证书前）
# init-ssl.sh 成功后会自动改为 ./nginx.conf
NGINX_CONF=
